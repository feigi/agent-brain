{
  "name": "agentic-brain",
  "version": "0.1.0",
  "type": "module",
  "description": "A long-term memory system for AI agents, exposed as an MCP server",
  "scripts": {
    "dev": "docker compose -f docker-compose.yml -f docker-compose.ollama.yml up -d --wait && npx drizzle-kit migrate && EMBEDDING_PROVIDER=ollama EMBEDDING_DIMENSIONS=768 tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect": "npx @modelcontextprotocol/inspector npx tsx src/server.ts",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6",
    "postgres": "^3.4.8",
    "drizzle-orm": "^0.45.1",
    "pgvector": "^0.2.1",
    "@aws-sdk/client-bedrock-runtime": "^3.1014.0",
    "nanoid": "^5.1.7",
    "dotenv": "^16.0.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "vitest": "^4.1.0",
    "@modelcontextprotocol/inspector": "^0.21.1",
    "typescript": "^5.9.3",
    "@types/node": "^22.0.0"
  }
}
