{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/memory-session-start.sh",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/memory-nudge.sh",
        "timeoutSec": 5
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/memory-session-end.sh",
        "timeoutSec": 5
      }
    ]
  }
}
